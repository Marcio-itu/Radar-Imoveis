name: Buscar imóveis

on:
  schedule:
    # Roda a cada 12 horas. Horário em UTC (Brasil = UTC-3, sem horário de verão).
    - cron: "0 */12 * * *"
  workflow_dispatch: {}
    # Isso permite rodar manualmente: no GitHub, aba "Actions" > "Buscar imóveis" > "Run workflow"

permissions:
  contents: write

# Garante que só uma execução deste workflow roda por vez. Se o agendamento
# automático e um "Run workflow" manual coincidirem, a segunda execução
# espera a primeira terminar (e já parte do repositório atualizado) em vez
# de rodar em paralelo e disputar o mesmo commit — foi isso que causou o
# "CONFLICT (content): Merge conflict in imoveis.json".
concurrency:
  group: buscar-imoveis
  cancel-in-progress: false

jobs:
  buscar:
    runs-on: ubuntu-latest
    steps:
      - name: Baixar o repositório
        uses: actions/checkout@v4

      - name: Configurar Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "20"

      - name: Rodar a busca
        env:
          SCRAPINGBEE_API_KEY: ${{ secrets.SCRAPINGBEE_API_KEY }}
        run: node scripts/buscar.mjs

      - name: Salvar resultado no repositório
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add imoveis.json
          if ! git diff --staged --quiet; then
            git commit -m "Atualiza imoveis.json [automático]"
            git fetch origin main

            if ! git rebase origin/main; then
              # imoveis.json é 100% gerado automaticamente (ninguém edita à
              # mão), então em caso de conflito é seguro manter a versão que
              # acabou de ser coletada nesta execução, em vez de travar o
              # workflow esperando resolução manual.
              echo "Conflito em imoveis.json durante o rebase — mantendo a versão recém-coletada."
              git checkout --ours -- imoveis.json
              git add imoveis.json
              git rebase --continue
            fi

            git push
          else
            echo "Nada mudou em imoveis.json, nada para salvar."
          fi
